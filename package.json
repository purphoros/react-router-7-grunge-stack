{
  "name": "grunge-stack-template",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "build": "react-router build && cp arc-handler.mjs build/server/index.mjs && cp arc-package.json build/server/package.json",
    "dev": "run-p dev:*",
    "dev:arc": "arc sandbox -e testing -q",
    "dev:vite": "cross-env ARC_ENV=testing ARC_TABLES_PORT=5555 AWS_ACCESS_KEY_ID=testing AWS_SECRET_ACCESS_KEY=testing AWS_REGION=us-west-2 react-router dev",
    "format": "prettier --write .",
    "format:repo": "npm run format && npm run lint -- --fix",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "start": "cross-env NODE_ENV=production arc sandbox",
    "test": "vitest",
    "test:e2e:dev": "start-server-and-test dev http://localhost:5173 \"npx cypress open\"",
    "test:e2e:run": "npm-run-all --parallel dev:arc test:e2e:serve",
    "test:e2e:serve": "cross-env ARC_ENV=testing ARC_TABLES_PORT=5555 AWS_ACCESS_KEY_ID=testing AWS_SECRET_ACCESS_KEY=testing AWS_REGION=us-west-2 start-server-and-test \"react-router dev --port 8811\" http://localhost:8811 \"npx cypress run\"",
    "typecheck": "react-router typegen && tsc && tsc -p cypress",
    "validate": "run-p \"test -- --run\" lint typecheck test:e2e:run"
  },
  "eslintIgnore": [
    "/node_modules",
    "/build",
    "/public/build"
  ],
  "dependencies": {
    "@architect/architect": "^11.1.0",
    "@architect/functions": "^8.1.6",
    "@paralleldrive/cuid2": "^2.2.2",
    "@react-router/architect": "^7.13.1",
    "@react-router/node": "^7.13.1",
    "@react-router/remix-routes-option-adapter": "^7.13.1",
    "bcryptjs": "2.4.3",
    "isbot": "^5.1.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "^7.13.1",
    "remix-flat-routes": "^0.8.5",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.0.3",
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/cypress": "^10.0.2",
    "@testing-library/jest-dom": "^6.5.0",
    "@types/bcryptjs": "2.4.6",
    "@types/eslint": "^8.56.12",
    "@types/node": "^20.16.10",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.3.2",
    "@vitest/coverage-v8": "^2.1.2",
    "cross-env": "^7.0.3",
    "cypress": "^13.15.0",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-import-resolver-typescript": "^3.6.3",
    "eslint-plugin-cypress": "^3.5.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-jest": "^28.8.3",
    "eslint-plugin-jest-dom": "^5.4.0",
    "eslint-plugin-jsx-a11y": "^6.10.0",
    "eslint-plugin-markdown": "^5.1.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-testing-library": "^6.3.0",
    "happy-dom": "^15.7.4",
    "mock-aws-s3": "^4.0.2",
    "msw": "^2.4.9",
    "npm-run-all": "^4.1.5",
    "prettier": "3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.8",
    "start-server-and-test": "^2.0.8",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.2",
    "vite": "^5.4.8",
    "vite-tsconfig-paths": "^5.0.1",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
